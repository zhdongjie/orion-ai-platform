# .env

# ===============================
# App
# ===============================
APP_NAME="Orion Enterprise AI Platform"
APP_VERSION="1.0.0"
APP_DESCRIPTION=""
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=true
API_PREFIX=/api/v1
ENVIRONMENT=dev
BACKEND_CORS_ORIGINS=["*"]
API_SECRET_KEY=orion_internal_secret_123
APP_LOG_LEVEL=info
LOG_DIR=logs

# ===============================
# AI 配置 qwen/zhipu
# ===============================
LLM_PROVIDER="qwen"

# ===============================
# Zhipu AI 配置
# ===============================
ZHIPU_API_KEY="你的Zhipu_Key"
ZHIPU_API_BASE="https://open.bigmodel.cn/api/paas/v4"
ZHIPU_MODEL_GLM="glm-4-flash"
ZHIPU_MODEL_EMBEDDING="glm-embedding-6b"
ZHIPU_EMBEDDING_DIM=4096


# ===============================
# Qwen 配置
# ===============================
QWEN_API_KEY="你的Qwen_Key"
QWEN_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL_LLM="qwen-plus"
QWEN_MODEL_EMBEDDING="text-embedding-v3"
QWEN_EMBEDDING_DIM=1024